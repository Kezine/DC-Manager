# Port d'écoute
PORT=3000
# Dossier des documents (registre + 1 fichier SQLite par document)
DOCS_DIR=./data/documents
# Dossier du client buildé (dist/netmap.html). Défaut : ../dist
CLIENT_DIR=../dist
# Préfixe des endpoints REST (doit matcher window.__NETMAP_CONFIG__.apiBaseUrl)
API_BASE=/api
# Niveau de logs serveur : error | warn | info | debug | trace
LOG_LEVEL=info

# --- Auth / SSO (SSO externe) ---
# URL du SSO qui valide la session et renvoie l'utilisateur (logged, adminRight, expireDate, …).
# Défaut = SSO externe. Mettre SSO_URL= (vide) pour le MODE DEV (utilisateur factice SUPER_ADMIN).
SSO_URL=https://sso.example.com/validate
# Nom du cookie contenant le JETON à proxifier au SSO (défaut SSO externe ; "" = en-tête Cookie complet).
COOKIE_NAME=SsoJWT
# URL de CONNEXION SSO affichée au client (bouton « Connexion » de l'écran d'accueil quand non authentifié).
# Vide = pas de bouton. La macro ${clbkUrl} est remplacée par l'URL courante (encodée) pour le retour après login.
# LOGIN_URL=https://sso.example.com/login?service=${clbkUrl}
# Nom de l'utilisateur factice en MODE DEV (SSO_URL vide).
DEV_USER=dev
# DEV : gate HTTP Basic Auth (user:pass) — PRIORITAIRE sur le SSO. Le navigateur demande user/mdp.
# BASIC_AUTH=dev:secret
