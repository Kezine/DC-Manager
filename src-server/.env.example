# Port d'écoute
PORT=3000
# Dossier des documents (registre + 1 fichier SQLite par document)
DOCS_DIR=./data/documents
# Dossier du client buildé (dist/netmap.html). Défaut : ../dist
CLIENT_DIR=../dist
# Préfixe des endpoints REST (doit matcher window.__NETMAP_CONFIG__.apiBaseUrl)
API_BASE=/api

# --- Auth / SSO ---
# URL d'un endpoint SSO qui VALIDE la session (cookies/Authorization transmis tels quels) et
# renvoie l'utilisateur en JSON. Si non défini → mode DEV (utilisateur factice).
# SSO_URL=https://sso.example.com/userinfo
# Utilisateur factice en l'absence de SSO_URL. Mettre DEV_USER="" pour simuler un 401 (non connecté).
DEV_USER=dev
