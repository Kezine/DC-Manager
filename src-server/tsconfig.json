{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "dist",
    // rootDir = parent commun de `src` et `../shared` (le code partagé est compilé AVEC le serveur).
    // Conséquence : l'entrée émise devient `dist/src-server/src/index.js` (cf. package.json start/main).
    "rootDir": "..",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": false,
    "sourceMap": false
  },
  "include": ["src/**/*.ts", "../shared/**/*.ts"]
}
